# ================================
# IntellBank AI Service – .env
# ================================

# Path to your fine-tuned FLAN-T5-small model weights
# After training, run: python app/training/train_question_generator.py
HUGGINGFACE_MODEL_PATH=./app/models/question_generator

# Path to the trained topic predictor
TOPIC_PREDICTOR_PATH=./app/models/topic_predictor

# (Optional) If using an external OCR API, set the key here
# OCR_API_KEY=

# Port (default 8000)
PORT=8000
