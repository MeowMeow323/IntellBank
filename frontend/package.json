{
  "name": "intellbank-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "start-ai": "cd ../ai-service && .\\venv\\Scripts\\python.exe -m uvicorn app.main:app --port 8000 --reload",
    "start-spring": "cd ../backend && .\\mvnw spring-boot:run",
    "start-all": "concurrently \"npm run start-ai\" \"npm run start-spring\" \"npm run dev\"",
    "update-ai": "cd ../ai-service && .\\venv\\Scripts\\python.exe app/tools/ocr_to_db.py && .\\venv\\Scripts\\python.exe app/tools/merge_datasets.py && .\\venv\\Scripts\\python.exe app/training/train_question_generator.py"
  },
  "dependencies": {
    "@matejmazur/react-katex": "^3.1.3",
    "axios": "^1.6.8",
    "katex": "^0.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "recharts": "^2.12.7",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.2.1",
    "vite": "^5.2.11",
    "vitest": "^1.6.0"
  }
}
