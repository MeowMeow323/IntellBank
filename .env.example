# ==============================================================================
# IntellBank – Global Environment Variables Configuration Template
# ==============================================================================
# Copy this file to '.env' at the repository root and fill in your real values.
# DO NOT commit the actual '.env' file to Git (it is in .gitignore).
# ==============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# ── 1. DATABASE (Supabase PostgreSQL)
# ──────────────────────────────────────────────────────────────────────────────
# Used by:
# - ai-service (app/tools/ocr_to_dataset.py) to read past_year_papers table
# - backend (Spring Boot application.properties) for JPA/Hibernate connection
# Find these in: Supabase Dashboard → Settings → Database → Connection Info
# ──────────────────────────────────────────────────────────────────────────────
SUPABASE_DB_HOST=aws-1-ap-southeast-2.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.aqasqvvygcwysalhpexf
SUPABASE_DB_PASSWORD=IntellBank123!

# ──────────────────────────────────────────────────────────────────────────────
# ── 2. BACKEND SERVICE (Spring Boot)
# ──────────────────────────────────────────────────────────────────────────────
# Port on which the Spring Boot API Gateway runs
BACKEND_PORT=8080

# JWT Security Configurations
# Use a strong, random, secret key of at least 256 bits for production
JWT_SECRET=Intellbank-default-secret-change-in-production-256bits
JWT_EXPIRATION=86400000

# ──────────────────────────────────────────────────────────────────────────────
# ── 3. AI SERVICE (FastAPI)
# ──────────────────────────────────────────────────────────────────────────────
# Port on which the FastAPI AI Service runs
AI_SERVICE_PORT=8000
AI_SERVICE_BASE_URL=http://localhost:8000

# Local model storage directories
HUGGINGFACE_MODEL_PATH=./app/models/question_generator
TOPIC_PREDICTOR_PATH=./app/models/topic_predictor

# ──────────────────────────────────────────────────────────────────────────────
# ── 4. OCR.space API
# ──────────────────────────────────────────────────────────────────────────────
# Used by: ai-service (app/tools/ocr_to_dataset.py)
# Get a free key at: https://ocr.space/ocrapi
OCR_SPACE_API_KEY=K87303120788957

# Legacy aliases kept for backward compatibility with older scripts
OCR_API_KEY=K87303120788957
OCR_API_URL=https://api.ocr.space/parse/image

# ──────────────────────────────────────────────────────────────────────────────
# ── 5. FRONTEND (Vite / React)
# ──────────────────────────────────────────────────────────────────────────────
# Base API URL to connect Vite Dev Server to Spring Boot Backend API
VITE_API_BASE_URL=http://localhost:8080
