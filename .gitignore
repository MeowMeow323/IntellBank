# ===========================
# IntellBank .gitignore
# ===========================

# ---- Node / Frontend ----
node_modules/
dist/
.env
.env.local
.env.production
frontend/.env
frontend/dist/
frontend/node_modules/

# ---- Java / Maven ----
backend/target/
# Do NOT ignore .mvn/ — it contains the Maven wrapper needed to build without Maven installed
*.class
*.jar
*.war
*.ear

# ⚠️ IMPORTANT: application.properties contains real DB credentials — never commit it
backend/src/main/resources/application.properties

# ---- Python / AI Service ----
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
ai-service/venv/
ai-service/.env
ai-service/app/models/question_generator/
ai-service/app/models/topic_predictor/
ai-service/app/data/raw/
ai-service/app/data/processed/
*.pt
*.bin
*.h5
*.onnx

# ---- IDEs ----
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---- OS ----
.DS_Store
Thumbs.db

# ---- Logs ----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Docker ----
docker-compose.override.yml
